<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme used before Compose takes over. Compose draws the real UI;
         this just sets the launch/window background so there's no white flash. -->
    <style name="Theme.Onward" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/pine</item>
    </style>
</resources>
